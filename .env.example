# Copy to .env for local development. Never commit real values.
FLASK_ENV=development
FLASK_DEBUG=false
FLASK_SECRET_KEY=replace-with-long-random-secret
DATABASE_URL=postgresql://postgres.PROJECT_ID:DATABASE_PASSWORD@REGION.pooler.supabase.com:6543/postgres?sslmode=require

SUPABASE_AUTH_ENABLED=true
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-me
SUPABASE_SECRET_KEY=replace-me
SUPABASE_EMAIL_REDIRECT_URL=http://127.0.0.1:5000/auth/callback
SUPABASE_STORAGE_BUCKET=career-documents

# Optional backward-compatible names:
# SUPABASE_ANON_KEY=replace-me
# SUPABASE_SERVICE_ROLE_KEY=replace-me

MAX_PDF_PAGES=10
MAX_CONTENT_LENGTH=10485760
SESSION_COOKIE_SECURE=false
SESSION_REDIS_URL=
SESSION_FILE_DIR=Backend/instance/sessions
RATELIMIT_STORAGE_URI=memory://
ADMIN_EMAILS=
